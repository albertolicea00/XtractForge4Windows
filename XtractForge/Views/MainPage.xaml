<UserControl
    x:Class="XtractForge.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:XtractForge.ViewModels"
    AllowDrop="True"
    DragOver="OnDragOver"
    Drop="OnDrop">

    <Grid RowSpacing="8" Padding="16,8,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Drop zone -->
        <Border x:Name="DropZone"
                Grid.Row="0"
                MinHeight="110"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                Background="{ThemeResource ControlFillColorDefaultBrush}">
            <StackPanel Spacing="4" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="16">
                <FontIcon Glyph="&#xE896;" FontSize="26"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Text="Drop a link to download"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Video, audio, galleries, streams, or direct files — or paste with Ctrl+V"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <Button Content="Paste URL" Margin="0,6,0,0" HorizontalAlignment="Center"
                        Command="{x:Bind ViewModel.PasteCommand}" />
            </StackPanel>
        </Border>

        <!-- Clipboard suggestion -->
        <InfoBar Grid.Row="1"
                 IsOpen="{x:Bind ViewModel.HasClipboardSuggestion, Mode=OneWay}"
                 Severity="Informational"
                 Title="Link on clipboard"
                 Message="{x:Bind ViewModel.ClipboardSuggestion, Mode=OneWay}"
                 CloseButtonClick="OnSuggestionDismissed">
            <InfoBar.ActionButton>
                <Button Content="Download"
                        Command="{x:Bind ViewModel.AcceptClipboardSuggestionCommand}" />
            </InfoBar.ActionButton>
        </InfoBar>

        <!-- Queue -->
        <ListView Grid.Row="2"
                  ItemsSource="{x:Bind ViewModel.Items}"
                  SelectionMode="None"
                  IsItemClickEnabled="False">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:DownloadItemViewModel">
                    <Grid ColumnSpacing="12" Padding="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <FontIcon Grid.Column="0" Glyph="{x:Bind StateGlyph, Mode=OneWay}"
                                  FontSize="16" VerticalAlignment="Center" />

                        <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                       TextTrimming="CharacterEllipsis" MaxLines="1" />
                            <ProgressBar Value="{x:Bind Percent, Mode=OneWay}" Maximum="100"
                                         IsIndeterminate="{x:Bind IsIndeterminate, Mode=OneWay}"
                                         Visibility="{x:Bind IsProgressVisible, Mode=OneWay}" />
                            <TextBlock Text="{x:Bind Subtitle, Mode=OneWay}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis" MaxLines="1" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                                    VerticalAlignment="Center">
                            <Button Command="{x:Bind PauseCommand}" ToolTipService.ToolTip="Pause"
                                    Visibility="{x:Bind CanPause, Mode=OneWay}">
                                <FontIcon Glyph="&#xE769;" FontSize="13" />
                            </Button>
                            <Button Command="{x:Bind ResumeCommand}" ToolTipService.ToolTip="Resume"
                                    Visibility="{x:Bind CanResume, Mode=OneWay}">
                                <FontIcon Glyph="&#xE768;" FontSize="13" />
                            </Button>
                            <Button Command="{x:Bind CancelCommand}" ToolTipService.ToolTip="Cancel"
                                    Visibility="{x:Bind CanCancel, Mode=OneWay}">
                                <FontIcon Glyph="&#xE711;" FontSize="13" />
                            </Button>
                            <Button Command="{x:Bind RevealCommand}"
                                    ToolTipService.ToolTip="Show in Explorer"
                                    Visibility="{x:Bind CanReveal, Mode=OneWay}">
                                <FontIcon Glyph="&#xE838;" FontSize="13" />
                            </Button>
                            <Button Command="{x:Bind RetryCommand}" ToolTipService.ToolTip="Retry"
                                    Visibility="{x:Bind CanRetry, Mode=OneWay}">
                                <FontIcon Glyph="&#xE72C;" FontSize="13" />
                            </Button>
                            <Button Command="{x:Bind RemoveCommand}"
                                    ToolTipService.ToolTip="Remove from list"
                                    Visibility="{x:Bind CanRemove, Mode=OneWay}">
                                <FontIcon Glyph="&#xE74D;" FontSize="13" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Empty state -->
        <StackPanel Grid.Row="2" Spacing="6"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}">
            <FontIcon Glyph="&#xE7B8;" FontSize="36"
                      Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            <TextBlock Text="No downloads yet"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>
